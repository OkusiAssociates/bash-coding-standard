#!/bin/bash
#shellcheck disable=SC2317  # Defensive: cleanup() is invoked via EXIT trap (indirect)
#
# shlock - File-based locking system with stale lock detection
#
# DESCRIPTION:
#   Provides exclusive file-based locking using flock(1) for safe concurrent
#   script execution. Prevents multiple instances of the same operation from
#   running simultaneously and includes stale lock detection for cleanup of
#   locks left behind by crashed processes.
#
# USAGE:
#   shlock [OPTIONS] [LOCKNAME] -- COMMAND [ARGS...]
#
# ARGUMENTS:
#   LOCKNAME    Unique identifier for the lock (e.g., 'myapp', 'backup')
#               If omitted, derived from basename of COMMAND
#   COMMAND     Command to execute while holding the lock
#   ARGS        Optional arguments passed to COMMAND
#
# OPTIONS:
#   -m, --max-age HOURS     Maximum lock age in hours (default: 24)
#   -w, --wait              Wait indefinitely for lock to become available
#   -t, --timeout SECONDS   Maximum time to wait for lock
#   -s, --steal             Forcefully remove existing lock (prompts only if process running)
#   -h, --help              Display this help message
#   -V, --version           Display version information
#
# LOCKING MECHANISM:
#   - Uses flock(1) on <LOCKDIR>/<LOCKNAME>.lock for exclusive locking
#   - PID file at <LOCKDIR>/<LOCKNAME>.pid tracks lock holder
#   - Lock directory fallback: /run/lock → /var/lock → /tmp/locks
#   - Non-blocking by default (fails immediately if lock is held)
#   - With -w/--wait: blocks until lock is available
#   - With -t/--timeout: waits up to specified seconds
#   - Stale lock detection: removes locks older than --max-age or with dead holders
#
# EXIT CODES (BCS-canonical):
#   0   - Command executed successfully (wrapped command exit code passed through)
#   1   - Lock held (non-timeout acquisition failure) or steal cancelled by user
#   2   - Usage error (missing COMMAND or -- separator)
#   13  - Permission denied (no writable lock directory)
#   22  - Invalid argument (unknown option, bad LOCKNAME, non-numeric value)
#   24  - Timeout (--timeout N expired)
#   *   - Any other code: propagated from the wrapped command
#
# EXAMPLES:
#   # Non-blocking lock (default)
#   shlock backup -- /usr/local/bin/backup.sh
#
#   # Auto-generate lock name from command
#   shlock -- /usr/local/bin/backup.sh
#
#   # Wait indefinitely for lock
#   shlock --wait deployment -- ./deploy.sh production
#
#   # Wait up to 30 seconds for lock
#   shlock --timeout 30 sync -- rsync -av /src /dest
#
#   # Custom stale lock threshold
#   shlock --max-age 12 critical -- /path/to/critical.sh
#
#   # Using short options (bundling supported, arg-taking option must be last)
#   shlock -wt 60 -m 6 backup -- /usr/local/bin/backup.sh
#
#   # Forcefully steal a held lock (prompts only if holder is running)
#   shlock --steal backup -- /usr/local/bin/backup.sh
#
# NOTES:
#   - Lock files persist after command completion for reuse
#   - PID files are cleaned up on exit
#   - flock is released when the script exits (normal or signal)
#   - --steal removes dead locks automatically, prompts only for running processes
#   - Safe for use in cron jobs and automated scripts

set -euo pipefail
shopt -s inherit_errexit shift_verbose
umask 0022

declare -rx PATH=${HOME:-/root}/.local/bin:/usr/local/bin:/usr/bin:/bin

# Script metadata
declare -r VERSION=2.0.0
declare -r SCRIPT_NAME=${0##*/}

# Global variables
declare -- LOCKNAME=''
declare -- LOCKFILE=''
declare -- PIDFILE=''
declare -i MAX_AGE_HOURS=24
declare -i WAIT_MODE=0
declare -i TIMEOUT_SECONDS=0
declare -i TIMEOUT_SET=0
declare -i STEAL_MODE=0

# Messaging functions -----------------

warn() { >&2 echo "$SCRIPT_NAME: ▲ $*"; }
error() { >&2 echo "$SCRIPT_NAME: ✗ $*"; }
die() { (($# < 2)) || error "${@:2}"; exit "${1:-1}"; }

yn() {
  local -- REPLY=''
  >&2 printf '%s: ▲ %s y/n ' "$SCRIPT_NAME" "${1:-Continue?}"
  read -r -t 30 -n 1 || { >&2 printf '\n'; return 1; }
  >&2 printf '\n'
  [[ ${REPLY,,} == y ]]
}

# Usage display -----------------------

show_help() {
  cat <<HELP
$SCRIPT_NAME $VERSION - file-based locking system with stale lock detection

Usage: $SCRIPT_NAME [OPTIONS] [LOCKNAME] -- COMMAND [ARGS...]

Runs COMMAND while holding an exclusive flock-based lock. Prevents multiple
instances of the same operation from running concurrently, with automatic
stale-lock cleanup for crashed holders.

Arguments:
  LOCKNAME                 Unique lock identifier (optional)
                           If omitted, derived from basename of COMMAND
  --                       Required separator between options and COMMAND

Options:
  -m, --max-age HOURS      Maximum lock age in hours (default: $MAX_AGE_HOURS)
  -w, --wait               Wait indefinitely for lock to become available
  -t, --timeout SECONDS    Maximum time to wait for lock
  -s, --steal              Forcefully remove existing lock (prompts if holder running)
  -h, --help               Display this help message
  -V, --version            Display version information

Exit codes (BCS-canonical):
  0                        Command executed successfully (wrapped exit passed through)
  1                        Lock held (non-timeout) or steal cancelled by user
  2                        Usage error (missing COMMAND or -- separator)
  13                       Permission denied (no writable lock directory)
  22                       Invalid argument (unknown option, bad LOCKNAME, non-numeric)
  24                       Timeout (--timeout N expired)
  *                        Any other code: propagated from the wrapped command

Examples:
  # Non-blocking (default)
  $SCRIPT_NAME backup -- /usr/local/bin/backup.sh

  # Auto-generate lock name from command basename
  $SCRIPT_NAME -- /usr/local/bin/backup.sh

  # Wait indefinitely for lock
  $SCRIPT_NAME --wait deployment -- ./deploy.sh

  # Wait up to 30 seconds
  $SCRIPT_NAME --timeout 30 sync -- rsync -av /src /dest

  # Custom stale-lock threshold
  $SCRIPT_NAME --max-age 12 critical -- /path/to/critical.sh

  # Short-option bundling
  $SCRIPT_NAME -t 60 -m 6 backup -- /usr/local/bin/backup.sh

  # Forcefully steal a held lock (prompts only if holder is running)
  $SCRIPT_NAME --steal backup -- /usr/local/bin/backup.sh
HELP
}

# Helper functions --------------------

# Validate that $2 exists and is numeric, die with error if not
arg2_num() {
  if (($# < 2)) || [[ ! $2 =~ ^[0-9]+$ ]]; then
    die 22 "${1@Q} requires a numeric argument"
  fi
}

# Determine lock directory with fallback
# Tries /run/lock, then /var/lock, then creates /tmp/locks, or fails
determine_lock_dir() {
  local -a lock_dirs=(/run/lock /var/lock)
  local -- dir

  # Try standard directories first
  for dir in "${lock_dirs[@]}"; do
    if [[ -d $dir && -w $dir ]]; then
      echo "$dir"
      return 0
    fi
  done

  # Fall back to /tmp/locks - create if needed, sticky-bit for multi-user safety
  dir=/tmp/locks
  if [[ ! -d $dir ]]; then
    mkdir -p "$dir" 2>/dev/null || return 1
    chmod 1777 "$dir" 2>/dev/null ||:
  fi

  if [[ -w $dir ]]; then
    echo "$dir"
    return 0
  fi

  # All options exhausted
  return 1
}

# Return 0 if $1 is a positive integer AND the process exists; 1 otherwise.
# Validates numeric to prevent kill -0 0 (signals caller's pgroup) on bad input.
is_process_running() {
  local -- pid=${1:-}
  [[ $pid =~ ^[1-9][0-9]*$ ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

# Read PID from pidfile, trim whitespace, validate numeric.
# Prints PID on success, 'unknown' on any failure.
read_holder_pid() {
  local -- pid
  [[ -s $PIDFILE ]] || { echo unknown; return; }
  pid=$(<"$PIDFILE") || { echo unknown; return; }
  pid=${pid//[[:space:]]/}
  [[ $pid =~ ^[1-9][0-9]*$ ]] || { echo unknown; return; }
  echo "$pid"
}

# Return 0 if $1 lockfile mtime is older than MAX_AGE_HOURS; 1 otherwise.
# Note: mtime is updated on each acquisition (file opened with '>'), so this
# tracks the most recent lock attempt, not the original creation time.
is_lock_stale() {
  local -- lockfile=$1
  local -i max_age_seconds=$((MAX_AGE_HOURS * 3600))

  [[ -f $lockfile ]] || return 1  # Not stale if doesn't exist

  local -- mtime
  mtime=$(stat -c %Y "$lockfile" 2>/dev/null) || {
    warn "Cannot stat ${lockfile@Q}; treating as not-stale"
    return 1
  }
  local -i lock_age=$((EPOCHSECONDS - mtime))

  ((lock_age > max_age_seconds))
}

clean_stale_lock() {
  warn "Lock is older than $MAX_AGE_HOURS hours, removing stale lock"
  rm -f "$LOCKFILE" "$PIDFILE" 2>/dev/null \
    || warn "Failed to remove stale lock files ${LOCKFILE@Q} ${PIDFILE@Q}"
}

cleanup() {
  trap - EXIT
  rm -f "$PIDFILE" 2>/dev/null ||:
  # flock is released when fd 200 closes; lock file persists for reuse
}

steal_lock() {
  # Check if lock exists
  if [[ ! -f $LOCKFILE ]]; then
    # No lock to steal, just proceed normally
    return 0
  fi

  # Read holder PID
  local -- holder_pid
  holder_pid=$(read_holder_pid)

  # Check if holder process is running
  if [[ $holder_pid != unknown ]] && is_process_running "$holder_pid"; then
    # Process is RUNNING - warn and prompt for confirmation
    warn "Lock ${LOCKNAME@Q} is held by RUNNING process PID $holder_pid"
    if ! yn 'Really steal this lock?'; then
      die 1 'Lock steal cancelled by user'
    fi
    warn "Stealing lock ${LOCKNAME@Q} from running process..."
  else
    # Process is DEAD - just clean up automatically (no prompt needed)
    warn "Removing abandoned lock ${LOCKNAME@Q} (process $holder_pid is dead)"
  fi

  # Remove lock and pid files
  rm -f "$LOCKFILE" "$PIDFILE" 2>/dev/null \
    || warn "Failed to remove lock files during steal"
}

# Main entry --------------------------

main() {
  while (($#)); do
    case $1 in
      -h|--help)
        show_help; return 0
        ;;
      -V|--version)
        printf '%s %s\n' "$SCRIPT_NAME" "$VERSION"; return 0
        ;;
      -m|--max-age)
        arg2_num "$@"; shift
        MAX_AGE_HOURS=$1
        ;;
      -w|--wait)
        WAIT_MODE=1
        ;;
      -t|--timeout)
        arg2_num "$@"; shift
        TIMEOUT_SECONDS=$1
        TIMEOUT_SET=1
        ;;
      -s|--steal)
        STEAL_MODE=1
        ;;
      --)
        shift
        break
        ;;
      -[mwtsVh]?*) # BCS0805 short option bundling
        set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue
        ;;
      -*)
        die 22 "Unknown option ${1@Q}"
        ;;
      *)
        # First non-option argument is the lock name
        LOCKNAME=$1
        [[ ${2:-} == '--' ]] || die 2 "Expected -- after LOCKNAME, got ${2:-<end-of-args>}"
        ;;
    esac
    shift
  done

  # Validate arguments
  (($#)) || die 2 'COMMAND is required'

  if [[ -z $LOCKNAME ]]; then
    # Auto-generate LOCKNAME from basename of COMMAND (if not provided)
    # Exit with error if LOCKNAME derivation fails
    LOCKNAME=${1##*/}
    [[ -n $LOCKNAME ]] || die 22 "LOCKNAME could not be acquired from ${1@Q}"
  fi

  [[ $LOCKNAME =~ ^[a-zA-Z0-9._-]+$ ]] || die 22 "Invalid LOCKNAME ${LOCKNAME@Q} (alphanumeric, dots, hyphens, underscores only)"
  [[ ! $LOCKNAME =~ ^\.+$ ]] || die 22 "Invalid LOCKNAME ${LOCKNAME@Q} (cannot be only dots)"

  # Determine lock directory with fallback
  local -- LOCK_DIR
  LOCK_DIR=$(determine_lock_dir) || die 13 'Cannot find or create writable lock directory'
  readonly -- LOCK_DIR

  LOCKFILE="$LOCK_DIR"/"$LOCKNAME".lock
  PIDFILE="$LOCK_DIR"/"$LOCKNAME".pid

  # Check if lock file exists: cleanup if stale by age, or if holder is dead
  if [[ -f $LOCKFILE ]]; then
    local -- old_pid
    old_pid=$(read_holder_pid)

    if is_lock_stale "$LOCKFILE"; then
      # Lock older than max-age: refuse if holder still running, else clean
      if [[ $old_pid != unknown ]] && is_process_running "$old_pid"; then
        error "Lock is stale but process $old_pid is still running"
        die 1 "Lock held by PID $old_pid (running for $MAX_AGE_HOURS+ hours)"
      fi
      clean_stale_lock
    elif [[ $old_pid != unknown ]] && ! is_process_running "$old_pid"; then
      # Lock within max-age but holder process is dead: reclaim
      warn "removing abandoned lock (holder PID $old_pid no longer running)"
      rm -f "$LOCKFILE" "$PIDFILE" 2>/dev/null \
        || warn "Failed to reclaim abandoned lock"
    fi
  fi

  if ((STEAL_MODE)); then
    steal_lock
  fi

  # Try to acquire lock using flock
  # Open file descriptor 200 for the lock file
  exec 200>"$LOCKFILE"

  # Determine flock options (timeout takes priority over wait mode)
  local -a flock_opts=()
  if ((TIMEOUT_SET)); then
    # Timeout mode: wait up to specified seconds (0 = effectively non-blocking)
    flock_opts=(-w "$TIMEOUT_SECONDS")
  elif ((WAIT_MODE)); then
    # Wait indefinitely (no options needed for flock)
    :
  else
    # Non-blocking mode (default)
    flock_opts=(-n)
  fi

  if ! flock "${flock_opts[@]}" 200; then
    # Lock acquisition failed
    if ((TIMEOUT_SET)); then
      die 24 "Timeout after $TIMEOUT_SECONDS seconds waiting for lock ${LOCKNAME@Q}"
    else
      local -- holder_pid
      holder_pid=$(read_holder_pid)
      if [[ $holder_pid != unknown ]]; then
        die 1 "Lock ${LOCKNAME@Q} is currently held by PID $holder_pid"
      else
        die 1 "Lock ${LOCKNAME@Q} is currently held"
      fi
    fi
  fi

  echo $$ > "$PIDFILE"

  trap cleanup EXIT

  local -i exit_code=0
  "$@" || exit_code=$?

  exit "$exit_code"
}

main "$@"
#fin
