#!/usr/bin/env bash
# dux - Quick directory size overview (sorted smallest to largest)
set -euo pipefail
shopt -s inherit_errexit shift_verbose extglob nullglob

# Lock down PATH for security
declare -rx PATH='/usr/local/bin:/usr/bin:/bin'

declare -r VERSION=1.4.4
declare -r SCRIPT_NAME=${0##*/} # Script basename only

# Global for trap cleanup
declare -- DIRSIZES_TMPFILE=''

# Runtime flags
declare -i FOLLOW_SYMLINKS=0 VERBOSE=1

# Core message functions
_msg() { >&2 printf "$SCRIPT_NAME: $1 %s\n" "${@:2}"; }
# Future expansion:
#info() { ((VERBOSE)) || return 0; _msg '◉' "$@"; }
error() { _msg '✗' "$@"; }
die() { (($# < 2)) || error "${@:2}"; exit "${1:-0}"; }

# --------------------------------------------------------------------------------
# Usage documentation
# --------------------------------------------------------------------------------
show_help() {
  cat <<HELP
$SCRIPT_NAME $VERSION - Quick directory size overview

Find out where your disk space is going. Shows the size of each subdirectory,
sorted smallest to largest (largest at bottom for easy viewing).

USAGE
  $SCRIPT_NAME [OPTIONS] [DIRECTORY]
  $SCRIPT_NAME -h | -V

OPTIONS
  -L             Follow symlinks
  -q, --quiet    Suppress permission errors
  -h, --help     Show this help
  -V, --version  Show version

EXAMPLES
  $SCRIPT_NAME              # Current directory
  $SCRIPT_NAME /var         # Check /var subdirectories
  $SCRIPT_NAME ~ | tail -5  # 5 largest in home directory
  sudo $SCRIPT_NAME /       # Full system (needs root)

OUTPUT
  <size>    <path>

  Sizes use IEC units (KiB, MiB, GiB). Tab-separated for easy parsing.
  Permission errors go to stderr; accessible content is still shown.

EXIT CODES
  0   Success
  2   Usage error (too many arguments)
  3   Directory not found
  5   I/O error (mktemp, du failure)
  22  Invalid option

More info: https://github.com/Open-Technology-Foundation/dux
HELP
}

# --------------------------------------------------------------------------------
# Cleanup function for trap
# --------------------------------------------------------------------------------
cleanup() {
  local -i exitcode=${1:-$?}
  trap - SIGINT SIGTERM EXIT
  [[ -z ${DIRSIZES_TMPFILE:-} ]] || rm -f "$DIRSIZES_TMPFILE"
  exit "$exitcode"
}

# --------------------------------------------------------------------------------
# Main function
# --------------------------------------------------------------------------------
main() {
  local -a dirs=()
  local -- dir='' hr_size=''
  local -- size=0

  # Parse arguments
  while (($#)); do case $1 in
      -L)           FOLLOW_SYMLINKS=1 ;;
      -v|--verbose) VERBOSE=1 ;;
      -q|--quiet)   VERBOSE=0 ;;
      -h|--help)    show_help; exit 0 ;;
      -V|--version) printf '%s %s\n' "$SCRIPT_NAME" "$VERSION"; exit 0 ;;
      --)           shift
                    #shellcheck disable=SC2015 # false positive
                    (($#)) && [[ -z $dir ]] && dir=$1 ||:
                    break ;;
      -[LvqhV]?*)   set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue ;;
      -*)           die 22 "Invalid option ${1@Q}" ;;
      *)            [[ -z $dir ]] || die 2 "Too many arguments ${1@Q}"
                    dir=$1 ;;
  esac; shift; done
  readonly -- FOLLOW_SYMLINKS VERBOSE

  # Default to current directory if no directory specified
  : "${dir:=./}"

  # Validate path is an existing directory
  [[ -d $dir ]] || die 3 "Not a directory ${dir@Q}"

  # Install trap before resource creation (BCS0110): ensures any signal
  # between mktemp and use cannot leave an orphan tmp file. cleanup() guards
  # against an unset DIRSIZES_TMPFILE so firing pre-mktemp is a no-op.
  trap 'cleanup $?' SIGINT SIGTERM EXIT
  DIRSIZES_TMPFILE=$(mktemp) || die 5 'Failed to create temporary file'

  # Collect target dir and immediate subdirectories (depth 0 + 1).
  # Stderr suppressed: permission errors on subtrees are non-fatal here.
  local -a find_opts=()
  #shellcheck disable=SC2015 # false positive
  ((FOLLOW_SYMLINKS)) && find_opts+=(-L) ||:
  readarray -t dirs < <(find "${find_opts[@]}" "$dir" -maxdepth 1 -type d 2>/dev/null ||:)

  # Defensive: find should always emit at least $dir; empty result indicates
  # find failed entirely (e.g. dir vanished between -d check and exec).
  ((${#dirs[@]})) || die 3 "No directories found in ${dir@Q}"

  # First pass: collect directory sizes directly using du
  # Temp file already created by mktemp, just ensure it's empty
  : > "$DIRSIZES_TMPFILE"

  local -- current_dir du_out
  for current_dir in "${dirs[@]}"; do
    # du -sb may exit 1 on permission errors but still emit a valid total on
    # stdout. Per BCS0605 this partial-output behavior is expected and safe to
    # accept; downstream validation rejects truly empty output.
    if ((VERBOSE)); then
      du_out=$(du -sb "$current_dir") ||:
    else
      du_out=$(du -sb "$current_dir" 2>/dev/null) ||:
    fi
    # Output format: "<bytes>\t<path>"; strip from first non-digit.
    size=${du_out%%[!0-9]*}
    [[ -n $size ]] || die 5 "Failed to calculate size for ${current_dir@Q}"

    printf '%15d 0 %s\n' "$size" "$current_dir" >> "$DIRSIZES_TMPFILE"
  done

  # Sort by size
  sort -n "$DIRSIZES_TMPFILE" -o "$DIRSIZES_TMPFILE"

  # Second pass: display with human-readable sizes while preserving order
  local -- output_dir
  while read -r size _ output_dir; do
    hr_size=$(numfmt --to=iec --suffix=B --format="%.1f" "$size")
    printf '%-10s\t%s\n' "$hr_size" "$output_dir"
  done < "$DIRSIZES_TMPFILE"

  # Clean up (trap will handle this, but being explicit)
  rm -f "$DIRSIZES_TMPFILE"

  return 0
}

main "$@"
#fin
