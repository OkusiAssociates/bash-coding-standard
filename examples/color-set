#!/bin/bash
#shellcheck disable=SC2015
# SC2015: All A && B || C patterns use || : (no-op) which cannot fail,
# making the pattern safe. Used for concise conditional execution.
#
# Set terminal color globals: basic (NC RED GREEN YELLOW CYAN),
# complete (+BLUE MAGENTA BOLD ITALIC UNDERLINE DIM REVERSE),
# and optional flags (VERBOSE DEBUG DRY_RUN PROMPT)

# color_set [basic|complete] [always|never|auto] [verbose] [flags]
#
# Export ANSI color variables as globals. Two tiers:
#   basic (default): NC RED GREEN YELLOW CYAN
#   complete: adds BLUE MAGENTA BOLD ITALIC UNDERLINE DIM REVERSE
# Color mode: always/never force on/off; auto (default) uses TTY detection.
# flags: set BCS _msg control vars (VERBOSE; +DEBUG DRY_RUN PROMPT
#        with complete). Preserves existing VERBOSE if already set.
# Returns 0 on success, 2 on invalid argument.
color_set() {
  local -i color=-1 complete=0 verbose=0 flags=0
  while (($#)); do
    case ${1:-auto} in
      complete) complete=1 ;;
      basic)    complete=0 ;;

      flags)    flags=1 ;;

      verbose|-v|--verbose)
                verbose=1 ;;

      always)   color=1 ;;
      never|none)
                color=0 ;;
      auto)     color=-1 ;;

      *)        >&2 echo "${FUNCNAME[0]}: âś— Invalid argument ${1@Q}"
                return 2 ;;
    esac
    shift
  done
  ((color == -1)) \
    && { [[ -t 1 && -t 2 ]] && color=1 || color=0; } ||:

  if ((flags)); then
    declare -igx -- VERBOSE=${VERBOSE:-1}
    ((complete)) && declare -igx -- DEBUG=0 DRY_RUN=1 PROMPT=1 || :
  fi

  if ((color)); then
    declare -gx -- NC=$'\033[0m' RED=$'\033[0;31m' \
      GREEN=$'\033[0;32m' YELLOW=$'\033[0;33m' CYAN=$'\033[0;36m'
    ((complete)) && declare -gx -- BLUE=$'\033[0;34m' \
      MAGENTA=$'\033[0;35m' BOLD=$'\033[1m' ITALIC=$'\033[3m' \
      UNDERLINE=$'\033[4m' DIM=$'\033[2m' REVERSE=$'\033[7m' || :
  else
    declare -gx -- NC='' RED='' GREEN='' YELLOW='' CYAN=''
    ((complete)) && declare -gx -- BLUE='' MAGENTA='' BOLD='' \
      ITALIC='' UNDERLINE='' DIM='' REVERSE='' || :
  fi

  if ((verbose)); then
    ((flags)) && declare -p VERBOSE || :
    declare -p NC RED GREEN YELLOW CYAN
    ((complete)) && {
      ((flags)) && declare -p DEBUG DRY_RUN PROMPT || :
      declare -p BLUE MAGENTA BOLD ITALIC UNDERLINE DIM REVERSE
    } || :
  fi

  return 0
}
declare -fx color_set

# Dual-purpose guard: when sourced, export color_set and optionally
# invoke it with any args passed to 'source' (e.g., source color-set
# complete flags); then return to caller without entering script mode.
[[ ${BASH_SOURCE[0]} == "$0" ]] \
  || { (($#)) && color_set "$@" ||:; return 0; }

# Strict mode deferred to here so set -e doesn't affect callers
# who source this file as a library.
set -euo pipefail
shopt -s inherit_errexit

declare -r VERSION=1.0.1

# Handle version request
if [[ ${1:-} =~ ^(-V|--version)$ ]]; then
  echo "color-set $VERSION"
  exit 0
fi

# Handle help requests
if [[ ${1:-} =~ ^(-h|--help|help)$ ]]; then
  cat <<HELP
color-set $VERSION [OPTIONS...]

Dual-purpose bash library for terminal color management
with ANSI escape codes.

MODES:
  Source as library:  source color-set; color_set [OPTIONS]
  Execute directly:   color-set [OPTIONS]

OPTIONS:
  complete          Enable complete color set (12 variables)
  basic             Enable basic color set (5 variables) [default]

  always            Force colors on
  never, none       Force colors off
  auto              Auto-detect TTY [default]

  verbose, -v       Print variable declarations
  --verbose

  flags             Set standard BCS globals for _msg system
                    messaging constructs
                    * With 'basic': Sets VERBOSE only
                    * With 'complete': Sets VERBOSE, DEBUG,
                      DRY_RUN, PROMPT

  -V, --version     Print version and exit
  -h, --help        Print this help and exit

BASIC TIER (5 variables):
  NC, RED, GREEN, YELLOW, CYAN

COMPLETE TIER (+7 additional variables):
  BLUE, MAGENTA, BOLD, ITALIC, UNDERLINE, DIM, REVERSE

EXAMPLES:
  color-set complete verbose
  color-set always
  source color-set complete && echo "\${RED}Error\${NC}"

OPTIONS can be combined in any order.
HELP
  exit 0
fi

color_set "$@"
#fin
