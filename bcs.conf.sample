# SPDX-License-Identifier: GPL-3.0-or-later
# bcs.conf — BCS toolkit configuration
# Install to: ~/.config/bcs/bcs.conf
#
# This file is sourced as bash. CLI flags override these settings.
# See: bcs check --help
# See: tests/accuracy/LLM-ACCURACY.md for detailed backend accuracy data.

# Default model. May be a built-in alias (sonnet, opus, haiku, flash, pro,
# flash-lite, gpt5, gpt5-mini, qwen, qwen-small) or a canonical model ID
# (claude-sonnet-4-6, gemini-2.5-pro, gpt-5, qwen3.5:14b, ...). The backend is
# resolved from the alias-expanded name:
#   claude-*           -> Anthropic API
#   gemini-*           -> Google Gemini API
#   gpt-* | o[0-9]*    -> OpenAI API
#   claude-code[:...]  -> Claude Code CLI
#   (anything else)    -> local Ollama (e.g. minimax-m2:cloud)
#
# Accuracy-tested recommendations (by use case):
#   Quick check:      gpt5             (10-15s, 0 false positives)
#   Daily dev:        sonnet           (28-87s, best accuracy/speed)
#   Pre-release:      claude-code:opus (2-24 min, highest accuracy)
BCS_MODEL=sonnet

# Default analysis depth: low, medium, high, max
# Each level sets max output tokens AND (on capable models) the thinking
# budget or reasoning_effort. See bcs check --help for the table.
# 'medium' is the recommended default for all backends.
# 'high' benefits Claude/OpenAI reasoning models; marginal elsewhere.
# 'max' should be avoided for Ollama cloud models (hallucination risk).
BCS_EFFORT=medium

# Treat warnings as violations: 0 or 1
BCS_STRICT=0

# Prepend `shellcheck --format=json -x` output to the LLM prompt as
# static-analysis context. Auto-skipped if shellcheck is not in PATH.
# Override per-call with --shellcheck / --no-shellcheck.
BCS_SHELLCHECK=1

# Override or extend the model alias map. Built-in aliases:
#   opus, sonnet, haiku, flash, pro, flash-lite, gpt5, gpt5-mini, qwen, qwen-small
# Add your own (or override defaults) with: MODEL_ALIASES[name]=canonical-id
#MODEL_ALIASES[sonnet]=claude-sonnet-4-7
#MODEL_ALIASES[mycloud]=minimax-m2:cloud
#MODEL_ALIASES[reviewer]=qwen3-coder:480b-cloud

# Override effort -> API parameters. Defaults shown.
# Anthropic constraint: EFFORT_THINKING[X] MUST be < EFFORT_TOKENS[X] - 1024.
#EFFORT_TOKENS[low]=4000
#EFFORT_TOKENS[medium]=8000
#EFFORT_TOKENS[high]=32000
#EFFORT_TOKENS[max]=64000

#EFFORT_THINKING[low]=0
#EFFORT_THINKING[medium]=2000
#EFFORT_THINKING[high]=8000
#EFFORT_THINKING[max]=16000

#EFFORT_REASONING[low]=minimal
#EFFORT_REASONING[medium]=low
#EFFORT_REASONING[high]=medium
#EFFORT_REASONING[max]=high

# Ollama Cloud models (run `ollama signin` once, then `ollama pull <model>`):
# ▲ Accuracy testing shows Ollama cloud models (minimax, glm, qwen) have
#   very low recall (0-0.5/8 on complex scripts) and non-deterministic
#   suppression handling. Use for offline/private checking only.
#   Prefer gpt5 (OpenAI) or sonnet (Anthropic) for accuracy.
# Available cloud models: minimax-m2:cloud, minimax-m2.7:cloud,
# qwen3-coder:480b-cloud, glm-5.1:cloud, deepseek-v3.1:671b-cloud

# Ollama server address
#OLLAMA_HOST=localhost:11434

# API keys (one needed per backend; auto-detect tries each in order)
#ANTHROPIC_API_KEY=
#GOOGLE_API_KEY=
#GEMINI_API_KEY=
#OPENAI_API_KEY=

#fin
