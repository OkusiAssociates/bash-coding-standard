#!/usr/bin/env bash
#shellcheck disable=SC2015
# bcs - Bash Coding Standard CLI toolkit
# BCS-compliant script with 6 subcommands for viewing, generating,
# and checking compliance with the Bash Coding Standard.
set -euo pipefail
shopt -s inherit_errexit shift_verbose extglob nullglob

declare -rx PATH=~/.local/bin:/usr/local/bin:/usr/bin:/bin

# Script metadata
declare -r VERSION=2.0.0
#shellcheck disable=SC2155
declare -r SCRIPT_PATH=$(realpath -e -- "$0")
declare -r SCRIPT_DIR=${SCRIPT_PATH%/*} SCRIPT_NAME=${SCRIPT_PATH##*/}

# Global variables
declare -i VERBOSE=1

# Color definitions
if [[ -t 1 && -t 2 ]]; then
  declare -r RED=$'\033[0;31m' GREEN=$'\033[0;32m' YELLOW=$'\033[0;33m' CYAN=$'\033[0;36m' BOLD=$'\033[1m' NC=$'\033[0m'
else
  declare -r RED='' GREEN='' YELLOW='' CYAN='' BOLD='' NC=''
fi

# ---- Messaging functions ----

_msg() {
  local -- prefix="$SCRIPT_NAME:" msg
  case ${FUNCNAME[1]} in
    success) prefix+=" ${GREEN}✓${NC}" ;;
    warn)    prefix+=" ${YELLOW}▲${NC}" ;;
    info)    prefix+=" ${CYAN}◉${NC}" ;;
    error)   prefix+=" ${RED}✗${NC}" ;;
    *)       ;;
  esac
  for msg in "$@"; do printf '%s %s\n' "$prefix" "$msg"; done
}

info()    { ((VERBOSE)) || return 0; >&2 _msg "$@"; }
success() { ((VERBOSE)) || return 0; >&2 _msg "$@"; }
warn()    { >&2 _msg "$@"; }
error()   { >&2 _msg "$@"; }
die()     { (($# < 2)) || error "${@:2}"; exit "${1:-0}"; }
noarg()   { (($# > 1)) || die 22 "Option ${1@Q} requires an argument"; }

# ---- Path resolution ----

# Find BASH-CODING-STANDARD.md using FHS-compliant search
find_bcs_md() {
  local -a search_paths=(
    "$SCRIPT_DIR"/data
    "${SCRIPT_DIR%/bin}/share/yatti/BCS/data"
    /usr/local/share/yatti/BCS/data
    /usr/share/yatti/BCS/data
  )
  local -- path
  for path in "${search_paths[@]}"; do
    if [[ -f "$path"/BASH-CODING-STANDARD.md ]]; then
      echo "$path"/BASH-CODING-STANDARD.md
      return 0
    fi
  done
  return 1
}

# Find data directory containing section files
find_data_dir() {
  local -a search_paths=(
    "$SCRIPT_DIR"/data
    "${SCRIPT_DIR%/bin}/share/yatti/BCS/data"
    /usr/local/share/yatti/BCS/data
    /usr/share/yatti/BCS/data
  )
  local -- path
  for path in "${search_paths[@]}"; do
    if [[ -d "$path" ]]; then
      echo "$path"
      return 0
    fi
  done
  return 1
}

# Find md2ansi for formatted output
find_md2ansi() {
  local -a search_paths=(
    "$SCRIPT_DIR"/examples/md2ansi
    "$SCRIPT_DIR"/lib/md2ansi
  )
  local -- path
  for path in "${search_paths[@]}"; do
    [[ -x "$path" ]] && { echo "$path"; return 0; } ||:
  done
  command -v md2ansi 2>/dev/null # Returns 0 if no error
}

