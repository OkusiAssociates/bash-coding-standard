# ---- Subcommand: display ----

cmd_display() {
  local -i force_cat=0 squeeze_blanks=0

  while (($#)); do case $1 in
    -c|--cat)     force_cat=1 ;;
    -f|--file)    find_bcs_md || die 3 'BASH-CODING-STANDARD.md not found'; return 0 ;;
    -s|--squeeze) squeeze_blanks=1 ;;
    -h|--help)    show_display_help; return 0 ;;
    -[cfsh]?*)    set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue ;;
    -*)           die 22 "Invalid option ${1@Q}" ;;
    *)            die 2 "Unexpected argument ${1@Q}" ;;
  esac; shift; done

  local -- bcs_file
  bcs_file=$(find_bcs_md) || die 3 'BASH-CODING-STANDARD.md not found'

  local -a cat_opts=()
  ((squeeze_blanks)) && cat_opts+=(-s) ||:

  if ((force_cat)); then
    cat "${cat_opts[@]}" -- "$bcs_file"
    return 0
  fi

  # Try md2ansi for formatted output if terminal
  if [[ -t 1 ]]; then
    local -- md2ansi_cmd
    md2ansi_cmd=$(find_md2ansi) || md2ansi_cmd=''
    if [[ -n "$md2ansi_cmd" ]]; then
      "$md2ansi_cmd" -- "$bcs_file" | less -FXRS
      return 0
    fi
  fi

  # Fallback to plain cat
  cat "${cat_opts[@]}" -- "$bcs_file"
}

# ---- Subcommand: template ----

cmd_template() {
  local -- template_type=basic
  local -- script_name=''
  local -- description='Script description'
  local -- version='1.0.0'
  local -- output_file=''
  local -i make_executable=0
  local -i force_overwrite=0

  while (($#)); do case $1 in
    -t|--type)     noarg "$@"; shift; template_type=$1 ;;
    -n|--name)     noarg "$@"; shift; script_name=$1 ;;
    -d|--desc)     noarg "$@"; shift; description=$1 ;;
    -V|--version)  noarg "$@"; shift; version=$1 ;;
    -o|--output)   noarg "$@"; shift; output_file=$1 ;;
    -x|--executable) make_executable=1 ;;
    -f|--force)    force_overwrite=1 ;;
    -h|--help)     show_template_help; return 0 ;;
    -[tndVoxfh]?*) set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue ;;
    -*)            die 22 "Invalid option ${1@Q}" ;;
    *)             die 2 "Unexpected argument ${1@Q}" ;;
  esac; shift; done

  # Validate template type
  case $template_type in
    minimal|basic|complete|library) ;;
    *) die 22 "Invalid template type ${template_type@Q} (valid: minimal, basic, complete, library)" ;;
  esac

  # Determine script name from output file if not specified
  if [[ -z "$script_name" ]]; then
    if [[ -n "$output_file" ]]; then
      script_name=${output_file##*/}; script_name=${script_name%.sh}
    else
      script_name=script
    fi
  fi

  # Find template file
  local -- data_dir
  data_dir=$(find_data_dir) || die 3 'Data directory not found'
  local -- template_file="$data_dir"/templates/"$template_type".sh.template
  [[ -f "$template_file" ]] || die 3 "Template not found ${template_file@Q}"

  # Check output file
  if [[ -n "$output_file" && -f "$output_file" ]] && ! ((force_overwrite)); then
    die 1 "Output file already exists ${output_file@Q} (use -f to overwrite)"
  fi

  # Read and substitute placeholders
  local -- content
  content=$(< "$template_file")
  content=${content//\{\{NAME\}\}/$script_name}
  content=${content//\{\{DESCRIPTION\}\}/$description}
  content=${content//\{\{VERSION\}\}/$version}

  # Write output
  if [[ -n "$output_file" ]]; then
    printf '%s\n' "$content" > "$output_file"
    info "Generated $template_type template ${output_file@Q}"
    if ((make_executable)); then
      chmod +x "$output_file"
      info "Made executable ${output_file@Q}"
    fi
  else
    printf '%s\n' "$content"
  fi
}

# ---- Subcommand: check ----

cmd_check() {
  local -- script_file='' model=sonnet
  local -i strict=0 quiet=0 fast=0

  while (($#)); do case $1 in
    -m|--model)  noarg "$@"; shift; model=$1 ;;
    -f|--fast)   fast=1 ;;
    -s|--strict) strict=1 ;;
    -q|--quiet)  quiet=1 ;;
    -h|--help)   show_check_help; return 0 ;;
    -[mfsqh]?*)  set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue ;;
    --)          shift; break ;;
    -*)          die 22 "Invalid option ${1@Q}" ;;
    *)
      [[ -z "$script_file" ]] || die 2 'Only one script file allowed'
      script_file=$1
      ;;
  esac; shift; done

  [[ -n "$script_file" ]] || die 2 'No script file specified'
  [[ -f "$script_file" ]] || die 3 "Script not found ${script_file@Q}"
  [[ -r "$script_file" ]] || die 13 "Cannot read ${script_file@Q}"
  script_file=$(realpath -e -- "$script_file")

  # Verify claude CLI is available
  command -v claude >/dev/null || die 18 'Claude CLI (claude) required but not found'

  # Find the standard document
  local -- bcs_file
  bcs_file=$(find_bcs_md) || die 3 'BASH-CODING-STANDARD.md not found'

  # Build the system prompt
  local -- system_prompt
  system_prompt=$(build_check_prompt "$bcs_file" "$strict")

  # Run compliance check
  ((quiet)) || info "Checking ${script_file@Q} against BCS..."
  local -- result
  local -i exit_code=0

  # cd to clean temp dir — prevents claude from loading local CLAUDE.md
  local -- original_dir=$PWD
  local -- check_dir
  check_dir=$(mktemp -d -t 'bcs-XXXXX')
  cd "$check_dir"
  [[ -d /run/user/"${EUID:?}" ]] && export TMPDIR=/run/user/"${EUID:?}" ||:

  local -a claude_args=(--model "$model" --system-prompt "$system_prompt")
  ((fast)) && claude_args+=(--effort low) ||:

  #shellcheck disable=SC1007
  result=$(CLAUDECODE= claude "${claude_args[@]}" -p "Script to validate:

\`\`\`bash
$(< "$script_file")
\`\`\`" 2>/dev/null) || exit_code=$?

  cd "$original_dir"
  rm -rf "$check_dir"

  if [[ -n "$result" ]]; then
    echo "$result"
  fi

  return "$exit_code"
}

# Build the system prompt for compliance checking
build_check_prompt() {
  local -- bcs_file=$1
  local -i strict=${2:-0}

  cat <<'PROMPT'
You are a Bash script compliance validator for the Bash Coding Standard (BCS).

Analyze the provided script against the BCS rules below. For each finding, report:
- The BCS code (e.g., BCS0101)
- Whether it is a VIOLATION, WARNING, or SUGGESTION
- The specific line(s) affected
- What is wrong and how to fix it

At the end, provide a summary with:
- Count of violations, warnings, and suggestions
- Compliance percentage (0-100)
- Overall assessment: COMPLIANT, NEEDS_WORK, or NON_COMPLIANT

Respect inline suppression directives. When you see:
  #bcscheck disable=BCS0101
the next line is exempt from that specific rule. Multiple codes can be comma-separated:
  #bcscheck disable=BCS0101,BCS0606
Do not report suppressed rules as violations, warnings, or suggestions. Note them separately as SUPPRESSED if present.

PROMPT

  if ((strict)); then
    echo 'STRICT MODE: Treat all warnings as violations.'
    echo ''
  fi

  echo '---'
  echo ''
  echo '# Bash Coding Standard (BCS) Rules'
  echo ''
  cat -- "$bcs_file"
}

# ---- Subcommand: codes ----

cmd_codes() {
  #shellcheck disable=SC2317
  while (($#)); do case $1 in
    -h|--help) show_codes_help; return 0 ;;
    -*)        die 22 "Invalid option ${1@Q}" ;;
    *)         die 2 "Unexpected argument ${1@Q}" ;;
  esac; shift; done

  local -- data_dir
  data_dir=$(find_data_dir) || die 3 'Data directory not found'

  # Extract all ## BCS#### headers from section files
  local -- line code title
  while IFS= read -r line; do
    # Match lines like: ## BCS0102 Shebang
    if [[ "$line" =~ ^##\ (BCS[0-9]+)\ (.+)$ ]]; then
      code=${BASH_REMATCH[1]}
      title=${BASH_REMATCH[2]}
      printf '%s %s\n' "$code" "$title"
    fi
  done < <(cat "$data_dir"/[0-9]*.md)
}

# ---- Subcommand: generate ----

cmd_generate() {
  local -- output_file=''

  while (($#)); do case $1 in
    -o|--output) noarg "$@"; shift; output_file=$1 ;;
    -h|--help)   show_generate_help; return 0 ;;
    -[oh]?*)     set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue ;;
    -*)          die 22 "Invalid option ${1@Q}" ;;
    *)           die 2 "Unexpected argument ${1@Q}" ;;
  esac; shift; done

  local -- data_dir
  data_dir=$(find_data_dir) || die 3 'Data directory not found'

  # Default output location
  [[ -n "$output_file" ]] || output_file="$data_dir"/BASH-CODING-STANDARD.md

  # Count section files
  local -a section_files=()
  local -- section_file
  for section_file in "$data_dir"/[0-9]*.md; do
    [[ "${section_file##*/}" == BASH-CODING-STANDARD.md ]] && continue ||:
    section_files+=("$section_file")
  done

  ((${#section_files[@]})) || die 3 "No section files found in ${data_dir@Q}"

  info "Generating standard from ${#section_files[@]} section files..."

  {
    # Header
    echo '# Bash Coding Standard (BCS)'
    echo ''
    echo '**Concise, actionable coding rules for Bash 5.2+**'
    echo ''
    echo 'Designed by Okusi Associates for the Indonesian Open Technology Foundation (YaTTI).'
    echo 'Target audience: both human programmers and AI assistants.'
    echo ''
    echo '## Coding Principles'
    echo '- K.I.S.S.'
    echo '- "The best process is no process"'
    echo '- "Everything should be made as simple as possible, but not any simpler."'
    echo ''
    echo '**Critical:** Do not over-engineer scripts; remove unused functions and variables.'
    echo ''
    echo '## Contents'
    echo '1. Script Structure & Layout'
    echo '2. Variables & Data Types'
    echo '3. Strings & Quoting'
    echo '4. Functions & Libraries'
    echo '5. Control Flow'
    echo '6. Error Handling'
    echo '7. I/O & Messaging'
    echo '8. Command-Line Arguments'
    echo '9. File Operations'
    echo '10. Security'
    echo '11. Concurrency & Jobs'
    echo '12. Style & Development'
    echo ''
    echo '---'
    echo ''

    # Concatenate section files
    local -i first=1
    for section_file in "${section_files[@]}"; do
      if ((first)); then
        first=0
      else
        echo ''
        echo '---'
        echo ''
      fi
      cat -- "$section_file"
    done
  } > "$output_file"

  local -i line_count
  line_count=$(wc -l < "$output_file")
  success "Generated ${output_file@Q} ($line_count lines)"
}

# ---- Subcommand: help ----

cmd_help() {
  if ! (($#)); then
    show_main_help
    return 0
  fi

  case $1 in
    display)  show_display_help ;;
    template) show_template_help ;;
    check)    show_check_help ;;
    codes)    show_codes_help ;;
    generate) show_generate_help ;;
    help)     show_main_help ;;
    *)        error "Unknown command ${1@Q}"; show_main_help; return 2 ;;
  esac
}

# ---- Main dispatcher ----

main() {
  local -- subcmd

  if (($#)); then
    subcmd=$1
    shift
  else
    subcmd=display
  fi

  # Handle global options
  case $subcmd in
    -V|--version)
      echo "$SCRIPT_NAME $VERSION"
      return 0
      ;;
    -h|--help)
      show_main_help
      return 0
      ;;
  esac

  # Dispatch to subcommand
  case $subcmd in
    display)  cmd_display "$@" ;;
    template) cmd_template "$@" ;;
    check)    cmd_check "$@" ;;
    codes)    cmd_codes "$@" ;;
    generate) cmd_generate "$@" ;;
    help)     cmd_help "$@" ;;
    -*)
      # Treat unknown dash options as display options
      cmd_display "$subcmd" "$@"
      ;;
    *)
      error "Unknown command ${subcmd@Q}"
      show_main_help
      return 2
      ;;
  esac
}

main "$@"
#fin
